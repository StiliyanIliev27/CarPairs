@model CarPairs.Models.ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<h1 class="text-danger">Error</h1>
<h2>An error occurred while processing your request.</h2>

@if (Model?.ShowRequestId == true)
{
    <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
}

<a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary">Back to Home</a>
