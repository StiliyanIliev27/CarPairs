@{
    ViewData["Title"] = "Home Page";
}

<div class="cp-hero p-5 mb-5 text-center">
    <div class="cp-hero-icon mb-3">
        <i class="bi bi-gear-wide-connected"></i>
    </div>
    <h1 class="display-5 fw-bold mb-2">Welcome to CarPairs</h1>
    <p class="lead text-white-50 mb-4">Your central hub for managing car parts and manufacturer data.</p>
    <div class="d-flex flex-wrap justify-content-center gap-3">
        <a asp-controller="Parts" asp-action="Index" class="btn btn-warning btn-lg fw-semibold px-4">
            <i class="bi bi-tools me-2"></i>Browse Parts
        </a>
        <a asp-controller="Manufacturers" asp-action="Index" class="btn btn-outline-light btn-lg px-4">
            <i class="bi bi-building me-2"></i>View Manufacturers
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="cp-card p-4 h-100 text-center">
            <i class="bi bi-tools fs-1 text-warning mb-3 d-block"></i>
            <h5 class="fw-semibold">Parts Catalogue</h5>
            <p class="text-muted small mb-3">Browse, search, and manage car parts across all categories and
                manufacturers.</p>
                <a asp-controller="Parts" asp-action="Index" class="btn btn-sm btn-outline-dark">Go to Parts <i
                    class="bi bi-arrow-right ms-1"></i></a>
                </div>
            </div>
            <div class="col-md-4">
                <div class="cp-card p-4 h-100 text-center">
                    <i class="bi bi-building fs-1 text-warning mb-3 d-block"></i>
                    <h5 class="fw-semibold">Manufacturers</h5>
                    <p class="text-muted small mb-3">Manage manufacturer profiles including country of origin, founding year,
                        and website.</p>
                        <a asp-controller="Manufacturers" asp-action="Index" class="btn btn-sm btn-outline-dark">Go to Manufacturers
                            <i class="bi bi-arrow-right ms-1"></i></a>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="cp-card p-4 h-100 text-center">
                            <i class="bi bi-shield-lock fs-1 text-warning mb-3 d-block"></i>
                            <h5 class="fw-semibold">Secure Access</h5>
                            <p class="text-muted small mb-3">Role-based access for Admins, Managers, and Users. Register or log in to
                                get started.</p>
                                @if (User.Identity?.IsAuthenticated != true)
                                {
                                    <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-outline-dark">Login <i
                                        class="bi bi-arrow-right ms-1"></i></a>
                                    }
            else
                                    {
                                        <span class="badge bg-success py-2 px-3"><i class="bi bi-check-circle me-1"></i>Signed in</span>
                                    }
                                </div>
                            </div>
                        </div>