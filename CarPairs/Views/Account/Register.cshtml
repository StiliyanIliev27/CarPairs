@model CarPairs.Controllers.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="cp-auth-wrapper">
    <div class="cp-auth-card">
        <div class="cp-card p-4 p-md-5">
            <div class="text-center mb-4">
                <i class="bi bi-person-plus fs-1 text-warning"></i>
                <h2 class="fw-bold mt-2 mb-0">Create an account</h2>
                <p class="text-muted small">Join CarPairs to manage parts and manufacturers</p>
            </div>

            <form asp-action="Register" method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Email" class="form-control" autocomplete="username" aria-required="true"
                           placeholder="name@example.com" id="Email" />
                    <label for="Email"><i class="bi bi-envelope me-1"></i>Email address</label>
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Password" class="form-control" autocomplete="new-password" aria-required="true"
                           placeholder="Password" id="Password" />
                    <label for="Password"><i class="bi bi-lock me-1"></i>Password</label>
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-4">
                    <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" aria-required="true"
                           placeholder="Confirm Password" id="ConfirmPassword" />
                    <label for="ConfirmPassword"><i class="bi bi-lock-fill me-1"></i>Confirm password</label>
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button id="register-submit" type="submit" class="w-100 btn btn-warning btn-lg fw-semibold">
                    <i class="bi bi-person-check me-2"></i>Create account
                </button>
            </form>

            <hr class="my-4" />
            <p class="text-center text-muted small mb-0">
                Already have an account?
                <a asp-action="Login" class="fw-semibold text-dark">Log in here</a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}