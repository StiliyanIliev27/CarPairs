@{
    ViewData["Title"] = "Access Denied";
}

<div class="d-flex flex-column align-items-center justify-content-center py-5 text-center">
    <i class="bi bi-shield-x text-danger" style="font-size: 4rem;"></i>
    <h1 class="fw-bold mt-3 mb-1">Access Denied</h1>
    <p class="text-muted mb-4">You don't have permission to view this page.</p>
    <div class="d-flex gap-2">
        <a asp-controller="Home" asp-action="Index" class="btn btn-dark">
            <i class="bi bi-house me-1"></i>Go Home
        </a>
        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">
            <i class="bi bi-box-arrow-in-right me-1"></i>Log in with a different account
        </a>
    </div>
</div>