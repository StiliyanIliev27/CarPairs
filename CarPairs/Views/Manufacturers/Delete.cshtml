@model CarPairs.API.DTOs.Manufacturers.ManufacturerReadDto
@{
    ViewData["Title"] = "Delete Manufacturer";
}

<div class="cp-page-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Manufacturers</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
        </ol>
    </nav>
</div>

<div class="cp-form-card">
    <div class="cp-card border-danger-subtle p-4">
        <div class="text-center mb-4">
            <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:2.5rem;"></i>
            <h2 class="fw-bold mt-2 mb-1">Delete Manufacturer?</h2>
            <p class="text-muted">This action cannot be undone.</p>
        </div>

        <div class="bg-light rounded p-3 mb-4">
            <dl class="row mb-0">
                <dt class="col-sm-4 text-muted">Name</dt>
                <dd class="col-sm-8 fw-semibold">@Model.Name</dd>
                <dt class="col-sm-4 text-muted">Country</dt>
                <dd class="col-sm-8">@(Model.Country ?? "—")</dd>
                <dt class="col-sm-4 text-muted">Founded</dt>
                <dd class="col-sm-8">@Model.FoundedYear</dd>
            </dl>
        </div>

        <form asp-action="DeleteConfirmed" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2 justify-content-center">
                <button type="submit" class="btn btn-danger px-4">
                    <i class="bi bi-trash me-1"></i>Yes, delete
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-x me-1"></i>Cancel
                </a>
            </div>
        </form>
    </div>
</div>