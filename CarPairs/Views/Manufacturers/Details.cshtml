@model CarPairs.API.DTOs.Manufacturers.ManufacturerReadDto
@{
    ViewData["Title"] = "Manufacturer Details";
}

<div class="cp-page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Manufacturers</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
            </ol>
        </nav>
        <h1 class="fw-bold mb-0"><i class="bi bi-building me-2 text-warning"></i>@Model.Name</h1>
    </div>
    <div class="d-flex gap-2">
        @if (User.IsInRole("Manager"))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
        }
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="cp-card p-4">
            <h6 class="text-muted text-uppercase small fw-semibold mb-3">Manufacturer details</h6>
            <dl class="row mb-0">
                <dt class="col-sm-4 text-muted">Name</dt>
                <dd class="col-sm-8 fw-semibold">@Model.Name</dd>

                <dt class="col-sm-4 text-muted">Country</dt>
                <dd class="col-sm-8">
                    <span class="badge bg-light text-dark border">
                        <i class="bi bi-geo-alt me-1"></i>@(Model.Country ?? "—")
                    </span>
                </dd>

                <dt class="col-sm-4 text-muted">Founded</dt>
                <dd class="col-sm-8">@Model.FoundedYear</dd>

                <dt class="col-sm-4 text-muted">Website</dt>
                <dd class="col-sm-8">
                    @if (!string.IsNullOrEmpty(Model.Website))
                    {
                        <a href="@Model.Website" target="_blank" rel="noopener" class="text-decoration-none">
                            <i class="bi bi-box-arrow-up-right me-1"></i>@Model.Website
                        </a>
                    }
                    else
                    {

                        <span class="text-muted">—</span>
                    }
                </dd>

                <dt class="col-sm-4 text-muted">Status</dt>
                <dd class="col-sm-8">
                    @if (Model.IsActive)
                    {
                        <span class="badge bg-success-subtle text-success border border-success-subtle">
                            <i class="bi bi-check-circle me-1"></i>Active
                        </span>
                    }
                    else
                    {
                        <span class="badge bg-secondary-subtle text-secondary border">Inactive</span>
                    }
                </dd>

                <dt class="col-sm-4 text-muted">Created</dt>
                <dd class="col-sm-8 text-muted small">@Model.CreatedAt</dd>
            </dl>
        </div>
    </div>
</div>