@model IEnumerable<PartDto>
@{
    ViewData["Title"] = "Parts";
}

<div class="cp-page-header">
    <div>
        <h1 class="fw-bold mb-0"><i class="bi bi-tools me-2 text-warning"></i>Parts</h1>
        <p class="text-muted small mb-0">Browse and manage all car parts</p>
    </div>
    <a asp-action="Create" class="btn btn-dark">
        <i class="bi bi-plus-lg me-1"></i>Add Part
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-tools fs-1 d-block mb-2"></i>
        <p>No parts found. <a asp-action="Create" class="fw-semibold">Add the first one</a>.</p>
    </div>
}
else
{
    <div class="cp-card overflow-hidden">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>@Html.DisplayNameFor(m => m.Name)</th>
                        <th>@Html.DisplayNameFor(m => m.Price)</th>
                        <th>Stock</th>
                        <th>Manufacturer</th>
                        <th>Category</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-semibold">@Html.DisplayFor(_ => item.Name)</td>
                            <td>
                                <span class="badge bg-warning-subtle text-dark border border-warning-subtle">
                                    $@Html.DisplayFor(_ => item.Price)
                                </span>
                            </td>
                            <td>
                                @if (item.StockQuantity <= 5)
                                {
                                    <span class="cp-stock-low" title="Low stock">
                                        <i class="bi bi-exclamation-triangle me-1"></i>@item.StockQuantity
                                    </span>
                                }
                                else
                                {
                                    <span class="cp-stock-ok">@item.StockQuantity</span>
                                }
                            </td>
                            <td>
                                <span class="text-muted small">
                                    @(item.ManufacturerName ?? "—")
                                </span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.CategoryName))
                                {
                                    <span class="badge bg-light text-dark border">@item.CategoryName</span>
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="btn-group btn-group-sm" role="group" aria-label="Part actions">
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-outline-secondary" title="Details">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-outline-danger" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
