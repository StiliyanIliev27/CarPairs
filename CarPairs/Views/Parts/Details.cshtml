@model PartDto
@{
    ViewData["Title"] = "Part Details";
}

<div class="cp-page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Parts</a></li>
                <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
            </ol>
        </nav>
        <h1 class="fw-bold mb-0"><i class="bi bi-tools me-2 text-warning"></i>@Model.Name</h1>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-dark">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
            <i class="bi bi-trash me-1"></i>Delete
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="cp-card p-4">
            <h6 class="text-muted text-uppercase small fw-semibold mb-3">Part details</h6>
            <dl class="row mb-0">
                <dt class="col-sm-5 text-muted">@Html.DisplayNameFor(m => m.Name)</dt>
                <dd class="col-sm-7 fw-semibold">@Html.DisplayFor(m => m.Name)</dd>

                <dt class="col-sm-5 text-muted">@Html.DisplayNameFor(m => m.Price)</dt>
                <dd class="col-sm-7">
                    <span class="badge bg-warning-subtle text-dark border border-warning-subtle">
                        $@Html.DisplayFor(m => m.Price)
                    </span>
                </dd>

                <dt class="col-sm-5 text-muted">Stock</dt>
                <dd class="col-sm-7">
                    @if (Model.StockQuantity <= 5)
                    {
                        <span class="cp-stock-low">
                            <i class="bi bi-exclamation-triangle me-1"></i>@Model.StockQuantity (low)
                        </span>
                    }
                    else
                    {
                        <span class="cp-stock-ok">@Model.StockQuantity</span>
                    }
                </dd>

                <dt class="col-sm-5 text-muted">Manufacturer</dt>
                <dd class="col-sm-7">@(Model.ManufacturerName ?? "—")</dd>

                <dt class="col-sm-5 text-muted">Category</dt>
                <dd class="col-sm-7">
                    @if (!string.IsNullOrEmpty(Model.CategoryName))
                    {
                        <span class="badge bg-light text-dark border">@Model.CategoryName</span>
                    }
                    else
                    {

                        <span class="text-muted">—</span>
                    }
                </dd>

                <dt class="col-sm-5 text-muted">Created</dt>
                <dd class="col-sm-7 text-muted small">@Html.DisplayFor(m => m.CreatedAt)</dd>
            </dl>
        </div>
    </div>
</div>