@model PartDto
@{
    ViewData["Title"] = "Delete Part";
}

<div class="cp-page-header">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb mb-0">
            <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Parts</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
        </ol>
    </nav>
</div>

<div class="cp-form-card">
    <div class="cp-card border-danger-subtle p-4">
        <div class="text-center mb-4">
            <i class="bi bi-exclamation-triangle-fill text-danger" style="font-size:2.5rem;"></i>
            <h2 class="fw-bold mt-2 mb-1">Delete Part?</h2>
            <p class="text-muted">This action cannot be undone.</p>
        </div>

        <div class="bg-light rounded p-3 mb-4">
            <dl class="row mb-0">
                <dt class="col-sm-4 text-muted">@Html.DisplayNameFor(m => m.Name)</dt>
                <dd class="col-sm-8 fw-semibold">@Html.DisplayFor(m => m.Name)</dd>

                <dt class="col-sm-4 text-muted">@Html.DisplayNameFor(m => m.Price)</dt>
                <dd class="col-sm-8">$@Html.DisplayFor(m => m.Price)</dd>

                <dt class="col-sm-4 text-muted">@Html.DisplayNameFor(m => m.StockQuantity)</dt>
                <dd class="col-sm-8">@Html.DisplayFor(m => m.StockQuantity)</dd>

                <dt class="col-sm-4 text-muted">Manufacturer</dt>
                <dd class="col-sm-8">@(Model.ManufacturerName ?? "—")</dd>

                <dt class="col-sm-4 text-muted">Category</dt>
                <dd class="col-sm-8">@(Model.CategoryName ?? "—")</dd>
            </dl>
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2 justify-content-center">
                <button type="submit" class="btn btn-danger px-4">
                    <i class="bi bi-trash me-1"></i>Yes, delete
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="bi bi-x me-1"></i>Cancel
                </a>
            </div>
        </form>
    </div>
</div>