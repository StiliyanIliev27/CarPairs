@model CreatePartDto
@{
    ViewData["Title"] = "Create Part";
    var manufacturers = ViewData["Manufacturers"] as SelectList ?? new SelectList(new List<SelectListItem>());
    var categories = ViewData["Categories"] as SelectList ?? new SelectList(new List<SelectListItem>());
}

<div class="cp-page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Parts</a></li>
                <li class="breadcrumb-item active" aria-current="page">Create</li>
            </ol>
        </nav>
        <h1 class="fw-bold mb-0"><i class="bi bi-plus-circle me-2 text-warning"></i>New Part</h1>
    </div>
</div>

<div class="cp-form-card">
    <div class="cp-card p-4">
        <form asp-action="Create" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

            <h6 class="text-muted text-uppercase small fw-semibold mb-3">Part information</h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Name" class="form-label fw-semibold"></label>
                    <input asp-for="Name" class="form-control" placeholder="Part name" />
                    <span asp-validation-for="Name" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="Price" class="form-label fw-semibold"></label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="Price" class="text-danger small"></span>
                </div>
                <div class="col-md-3">
                    <label asp-for="StockQuantity" class="form-label fw-semibold"></label>
                    <input asp-for="StockQuantity" type="number" class="form-control" placeholder="0" />
                    <span asp-validation-for="StockQuantity" class="text-danger small"></span>
                </div>
            </div>

            <hr class="my-4" />
            <h6 class="text-muted text-uppercase small fw-semibold mb-3">Classification</h6>
            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="ManufacturerId" class="form-label fw-semibold">Manufacturer</label>
                    <select asp-for="ManufacturerId" class="form-select" asp-items="manufacturers">
                        <option value="">-- Select Manufacturer --</option>
                    </select>
                    <span asp-validation-for="ManufacturerId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="CategoryId" class="form-label fw-semibold">Category</label>
                    <select asp-for="CategoryId" class="form-select" asp-items="categories">
                        <option value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="CategoryId" class="text-danger small"></span>
                </div>
            </div>

            <hr class="my-4" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark px-4">
                    <i class="bi bi-check-lg me-1"></i>Create
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="bi bi-x me-1"></i>Cancel
                </a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}