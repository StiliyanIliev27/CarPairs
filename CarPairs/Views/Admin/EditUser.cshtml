@model CarPairs.Web.Services.Interfaces.UpdateUserFormDto
@using CarPairs.Core
@{
    ViewData["Title"] = "Edit User";
    var userId = (string)ViewBag.UserId;
    var userEmail = ViewBag.UserEmail as string;
    var organizations = (List<CarPairs.Web.Services.Interfaces.AdminOrganizationDto>)ViewBag.Organizations;
}

<div class="cp-page-header">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1">
                <li class="breadcrumb-item"><a asp-action="Index" class="text-decoration-none">Admin</a></li>
                <li class="breadcrumb-item"><a asp-action="Users" class="text-decoration-none">Users</a></li>
                <li class="breadcrumb-item active" aria-current="page">Edit</li>
            </ol>
        </nav>
        <h1 class="fw-bold mb-0"><i class="bi bi-pencil me-2 text-warning"></i>Edit User</h1>
    </div>
</div>

<div class="cp-form-card">
    <div class="cp-card p-4">
        <form asp-action="EditUser" asp-route-id="@userId" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 small" role="alert"></div>

            <div class="row g-3">
                <div class="col-md-6">
                    <label asp-for="Role" class="form-label fw-semibold"></label>
                    <select asp-for="Role" class="form-select"
                            asp-items="@(new SelectList(Enum.GetValues<UserRole>()))">
                    </select>
                    <span asp-validation-for="Role" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <label asp-for="OrganizationId" class="form-label fw-semibold">Organization</label>
                    <select asp-for="OrganizationId" class="form-select">
                        <option value="">— None (System Admin) —</option>
                        @foreach (var org in organizations)
                        {
                            <option value="@org.Id">@org.Name</option>
                        }
                    </select>
                    <span asp-validation-for="OrganizationId" class="text-danger small"></span>
                </div>
                <div class="col-md-6">
                    <div class="form-check form-switch mt-2">
                        <input asp-for="IsActive" class="form-check-input" role="switch" />
                        <label asp-for="IsActive" class="form-check-label fw-semibold">Active</label>
                    </div>
                </div>
            </div>

            <hr class="my-4" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-dark px-4">
                    <i class="bi bi-check-lg me-1"></i>Save
                </button>
                <a asp-action="Users" class="btn btn-outline-secondary">
                    <i class="bi bi-x me-1"></i>Cancel
                </a>
            </div>
        </form>
    </div>
</div>
